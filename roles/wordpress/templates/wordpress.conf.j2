<VirtualHost *:80>
    ServerName {{ wp_sitename }}
    DocumentRoot {{ wp_install_dir }}

    <Directory {{ wp_install_dir }}>
        AllowOverride All
        Require all granted
    </Directory>

    ErrorLog ${APACHE_LOG_DIR}/wordpress_error.log
    CustomLog ${APACHE_LOG_DIR}/wordpress_access.log combined
</VirtualHost>
